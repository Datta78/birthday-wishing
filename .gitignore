# ========================================
# Dattatray Bhosale - .gitignore
# For birthday-wishing Project
# ========================================

# Environment & Secrets
.env
.env.local
*.key
credentials.json

# Logs
*.log
logs/
error.log

# OS Generated
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Python Specific (if using)
__pycache__/
*.pyc
*.pyo

# Temporary Files
temp/
tmp/
cache/

# Node.js (if used later)
node_modules/
npm-debug.log*

# Keep this comment at the bottom
