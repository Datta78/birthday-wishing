# ========================================
# Dattatray Bhosale - General .gitignore
# ========================================

# Dependencies & Build Folders
/node_modules/
vendor/
dist/
build/
coverage/

# Environment & Secret Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
config.php
database.php
*.key
*.pem

# PHP Specific
*.log
php_error_log
Thumbs.db
.DS_Store

# Composer
composer.phar
/vendor/

# Database & Backups
*.sql
*.bak
*.backup
dump.sql

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.project
.settings/
.classpath

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Java / Android Specific
*.class
*.jar
*.war
*.ear
*.apk
*.aab
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# JavaScript / Frontend
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.eslintcache

# Temporary & Cache
tmp/
temp/
cache/
*.cache
*.tmp

# Documentation & Notes (if you want to ignore)
*.md~ 
*.txt~

# Large Files (optional - uncomment if needed)
# *.zip
# *.rar
# *.7z

# Personal Folders (uncomment and customize)
# /personal/
# /private/

# ========================================
# Keep this comment at the bottom
