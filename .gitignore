# === Environment & Secrets ===
.env
.env.local
*.key
credentials.json

# === Logs & Debugging ===
*.log
logs/
error.log
debug.log

# === OS Generated Files ===
.DS_Store
Thumbs.db

# === IDE / Editors ===
.vscode/
.idea/
*.swp
*.swo

# === Python ===
__pycache__/
*.pyc

# === Temporary Files ===
temp/
tmp/
cache/

# === Media & Large Files ===
*.mp4
*.zip
*.rar

